<Page x:Class="GuitarToolkit.Pages.MetronomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ — Маятник -->
        <Grid Grid.Column="0">
            <Canvas x:Name="PendulumCanvas" HorizontalAlignment="Center" VerticalAlignment="Center"
        Width="160" Height="360">

                <!-- BPM над маятником — кликабельный для ввода -->
                <TextBox x:Name="BpmLabel"
         Text="120"
         FontSize="48" FontWeight="Bold"
         Foreground="#CDD6F4"
         Background="Transparent"
         BorderThickness="0"
         TextAlignment="Center"
         Canvas.Left="0" Canvas.Top="0"
         Width="160"
         CaretBrush="#CDD6F4"
         SelectionBrush="#89B4FA"
         KeyDown="BpmInput_KeyDown"
         LostFocus="BpmInput_LostFocus"/>

                <!-- Точка опоры -->
                <Ellipse Width="12" Height="12"
             Fill="#6C7086"
             Canvas.Left="74" Canvas.Top="70"/>

                <!-- Стержень маятника -->
                <Line x:Name="PendulumRod"
      X1="80" Y1="76"
      X2="80" Y2="310"
      Stroke="#89B4FA" StrokeThickness="3"
      StrokeStartLineCap="Round"
      StrokeEndLineCap="Round"
      Canvas.ZIndex="1">
                    <Line.RenderTransform>
                        <RotateTransform x:Name="PendulumRotate" CenterX="80" CenterY="76"/>
                    </Line.RenderTransform>
                </Line>

                <!-- Груз маятника -->
                <Ellipse x:Name="PendulumBob"
         Width="36" Height="36"
         Fill="#89B4FA"
         Canvas.Left="62" Canvas.Top="292"
         Canvas.ZIndex="2">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="BobRotate" CenterX="0" CenterY="-216"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

            </Canvas>
        </Grid>

        <!-- ПРАВАЯ ЧАСТЬ — Управление -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Width="320">

            <!-- BPM подпись -->
            <TextBlock Text="BPM" FontSize="14" Foreground="#6C7086"
                       HorizontalAlignment="Center" Margin="0 0 0 4"/>

            <!-- Слайдер BPM -->
            <Slider x:Name="BpmSlider"
                    Minimum="20" Maximum="400" Value="120"
                    TickFrequency="1" IsSnapToTickEnabled="True"
                    Foreground="#89B4FA"
                    ValueChanged="BpmSlider_ValueChanged"
                    Margin="0 0 0 4"/>

            <Grid Margin="0 0 0 20">
                <TextBlock Text="20" Foreground="#6C7086" FontSize="11" HorizontalAlignment="Left"/>
                <TextBlock Text="400" Foreground="#6C7086" FontSize="11" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Громкость -->
            <TextBlock Text="Громкость" FontSize="14" Foreground="#6C7086"
                       HorizontalAlignment="Center" Margin="0 0 0 4"/>
            <Slider x:Name="VolumeSlider"
                    Minimum="0" Maximum="1" Value="0.8"
                    Foreground="#89B4FA"
                    Margin="0 0 0 20"/>

            <!-- Долей в такте -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0 0 0 24">
                <TextBlock Text="Долей в такте:" VerticalAlignment="Center"
                           Margin="0 0 12 0"/>
                <Button Content="−" Width="36" Height="36"
                        Click="DecrBeats_Click" FontSize="18"/>
                <TextBlock x:Name="BeatsLabel" Text="4"
                           FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="16 0" Foreground="#89B4FA"/>
                <Button Content="+" Width="36" Height="36"
                        Click="IncrBeats_Click" FontSize="18"/>
            </StackPanel>

            <!-- Tap Tempo -->
            <Button x:Name="TapButton"
                    Content="TAP TEMPO"
                    Height="52" FontSize="16" FontWeight="Bold"
                    Foreground="#1E1E2E" Background="#89B4FA"
                    Margin="0 0 0 12"
                    Click="TapButton_Click"/>

            <!-- Старт / Стоп -->
            <Button x:Name="StartStopButton"
                    Content="▶  СТАРТ"
                    Height="52" FontSize="16" FontWeight="Bold"
                    Foreground="#1E1E2E" Background="#A6E3A1"
                    Click="StartStop_Click"/>

        </StackPanel>
    </Grid>
</Page>